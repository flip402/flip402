# Solana RPC endpoint
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Payout wallet address (receives stakes, sends winnings)
NEXT_PUBLIC_PAYMENT_ADDRESS=YourSolanaWalletAddressHere

# Flip cost in SOL
NEXT_PUBLIC_FLIP_COST=0.005

# Jackpot range
NEXT_PUBLIC_JACKPOT_MAX=402

# Jackpot multiplier
NEXT_PUBLIC_JACKPOT_MULTIPLIER=380
